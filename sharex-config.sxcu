
{
  "Version": "14.1.0",
  "Name": "Kyle's Mystical ShareX",
  "DestinationType": "ImageUploader, TextUploader, FileUploader",
  "RequestMethod": "POST",
  "RequestURL": "https://mxtor",
  "Body": "MultipartFormData",
  "FileFormName": "file",
  "URL": "$json:url$",
  "ErrorMessage": "$json:error$",
  "Headers": {
    "User-Agent": "ShareX"
  }
}
